---

<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Todo</title>
		<meta name="description" content="A fast, Material Design 3 Todo application" />
		<meta name="theme-color" content="#6750a4" />
		<link rel="manifest" href="/manifest.json" />
		<link rel="apple-touch-icon" href="/icon-192.png" />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap"
		/>
	</head>
	<body>
		<div id="app"></div>
	</body>
</html>

<script>
	import '../styles/global.css'
	import { h, render } from 'preact'
	import App from '../components/App'
	import { initTheme } from '../settings'
	import { requestNotificationPermission, startNotificationChecker } from '../notifications'

	initTheme()
	render(h(App, null), document.getElementById('app')!)

	requestNotificationPermission().then((granted) => {
		if (granted) startNotificationChecker()
	})

	if ('serviceWorker' in navigator) {
		navigator.serviceWorker.register('/sw.js')
	}
</script>
